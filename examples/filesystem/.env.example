# ─── LLM API ───────────────────────────────────────────────────────────────
# Required. API key for the inference provider.
OPENAI_API_KEY=

# Inference base URL (default: Poolside)
OPENAI_API_BASE_URL=https://inference.poolside.ai/v1

# Model to use (default: poolside/laguna-xs.2)
OPENAI_MODEL=poolside/laguna-xs.2

# ─── MCP server ────────────────────────────────────────────────────────────
# Base URL of the running Filesystem MCP server (Streamable HTTP transport)
MCP_SERVER_URL=http://127.0.0.1:8765/filesystem

# ─── Filesystem sandbox ────────────────────────────────────────────────────
# Root directory exposed by the server — must match MCP_FS_ROOT on server.py
MCP_FS_ROOT=/tmp/sandbox

# ─── Optional overrides ────────────────────────────────────────────────────
# SYSTEM_PROMPT=You are a helpful file-management assistant...
